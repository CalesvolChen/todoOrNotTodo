# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址（模板内置 mock 鉴权使用）
VITE_GLOB_API_URL=/api

# Todo 业务后端（NestJS）地址，供任务/清单/统计页面使用
VITE_GLOB_TODO_API_URL=http://localhost:3000/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭（登录鉴权依赖它）
VITE_NITRO_MOCK=true

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
