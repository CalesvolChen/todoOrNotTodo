# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址（直连 NestJS 后端）
VITE_GLOB_API_URL=http://localhost:3000/api

# Todo 业务后端（NestJS）地址，供任务/清单/统计页面使用
VITE_GLOB_TODO_API_URL=http://localhost:3000/api

# 是否开启 Nitro Mock服务（已对接真实后端，关闭）
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
